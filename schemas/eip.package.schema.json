{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://embeddedx.dev/schemas/eip.package.schema.json",
  "title": "Embedded Intelligence Package v1",
  "type": "object",
  "required": [
    "packageId",
    "name",
    "version",
    "schemaVersion",
    "createdUtc",
    "model",
    "inputs",
    "outputs",
    "training",
    "artifacts"
  ],
  "properties": {
    "packageId": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "schemaVersion": { "const": "1.0.0" },
    "createdUtc": { "type": "string", "format": "date-time" },
    "model": {
      "type": "object",
      "required": ["modelFamily", "modelCategory", "targetClass", "parameterCount", "layerCount"],
      "properties": {
        "modelFamily": {
          "enum": [
            "linear", "ridge", "lasso", "logistic",
            "decision_tree", "random_forest", "gradient_boosting",
            "z_score", "ewma", "gaussian", "isolation_forest",
            "naive_bayes", "linear_svm", "knn", "small_mlp"
          ]
        },
        "modelCategory": {
          "enum": ["regression", "anomaly", "adaptive_reasoning", "state_machine", "classification", "future"]
        },
        "targetClass": { "enum": ["MCU", "MPU", "NPU"] },
        "parameterCount": { "type": "integer", "minimum": 0 },
        "layerCount": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "inputs": {
      "type": "array",
      "maxItems": 16,
      "items": {
        "type": "object",
        "required": ["inputId", "name", "enabled", "valueType", "semanticType", "unit", "sourceChannel"],
        "properties": {
          "inputId": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "enabled": { "type": "boolean" },
          "valueType": { "enum": ["bit", "byte", "numeric", "enum"] },
          "semanticType": { "type": "string", "minLength": 1 },
          "unit": { "type": "string", "minLength": 1 },
          "sourceChannel": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["outputId", "name", "enabled", "valueType", "semanticRole"],
        "properties": {
          "outputId": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "enabled": { "type": "boolean" },
          "valueType": { "enum": ["bit", "byte", "numeric", "enum", "string"] },
          "semanticRole": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "training": {
      "type": "object",
      "required": ["trainingMode", "labelStrategy", "datasetSummary"],
      "properties": {
        "trainingMode": { "enum": ["labeled_historical", "on_chip_recorded", "self_learning"] },
        "labelStrategy": { "enum": ["label_first", "train_first"] },
        "datasetSummary": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["artifactId", "artifactType", "path", "required"],
        "properties": {
          "artifactId": { "type": "string", "minLength": 1 },
          "artifactType": { "enum": ["cpp", "datasheet", "user_guide", "other"] },
          "path": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
